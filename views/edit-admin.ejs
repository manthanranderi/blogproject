<%- include('header') %>
    <%
        const hobbies = Array.isArray(admin.hobby) ? admin.hobby : [admin.hobby];
        const dobValue = admin.dob ? admin.dob.toISOString().slice(0, 10) : '';
    %>
    <div class="page-body">
        <div class="container-fluid">
            <div class="page-title">
                <div class="row">
                    <div class="col-12 col-sm-6">
                        <h3>Admin Form </h3>
                    </div>
                    <div class="col-12 col-sm-6">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/"> <i data-feather="home"></i></a></li>
                            <li class="breadcrumb-item"> Admin Layout</li>
                            <li class="breadcrumb-item active"> Edit Admin Forms</li>
                        </ol>
                    </div>
                </div>
            </div>
        </div>
        <!-- Container-fluid starts-->
        <div class="container-fluid">
            <div class="row">
                <div class="col-sm-12 col-xl-6">
                    <div class="row">
                        <div class="col-sm-12">
                            <div class="card">
                                <div class="card-header pb-0">
                                    <h5>Edit Admin Data </h5>
                                </div>
                                <div class="card-body">
                                    <form class="theme-form" action="/update-admin/<%= admin._id %>" method="post" enctype="multipart/form-data">
                                        <div class="mb-3">
                                            <label class="col-form-label pt-0">First
                                                Name</label>
                                            <input class="form-control" type="text" name="fname"
                                                placeholder="Enter Your First Name" value="<%= admin.fname || '' %>">
                                        </div>
                                        <div class="mb-3">
                                            <label class="col-form-label pt-0">Last
                                                Name</label>
                                            <input class="form-control" type="text" name="lname"
                                                placeholder="Enter Your Last Name" value="<%= admin.lname || '' %>">
                                        </div>
                                        <div class="mb-3">
                                            <label class="col-form-label pt-0">User
                                                Name</label>
                                            <input class="form-control" type="text" name="uname"
                                                placeholder="Enter Your User Name" value="<%= admin.uname || '' %>" required>
                                        </div>
                                        <div class="mb-3">
                                            <label class="col-form-label pt-0">Email
                                                address</label>
                                            <input class="form-control" type="email" name="email"
                                                placeholder="Enter Your Email Id" value="<%= admin.email || '' %>">
                                        </div>
                                        <div class="mb-3">
                                            <label class="col-form-label pt-0">Password</label>
                                            <input class="form-control" name="password" type="password"
                                                placeholder="Enter Your Password" disabled>
                                        </div>
                                        <div class="mb-3">
                                            <label class="col-form-label pt-0">Date Of Birth</label>
                                            <input class="datepicker-here form-control digits" type="text"
                                                data-language="en" name="dob" value="<%= dobValue %>">
                                        </div>
                                        <div class="mb-3">
                                            <label class="col-form-label pt-0">Contact Number</label>
                                            <input class="form-control" name="mobile" type="number"
                                                placeholder="Enter Your Contact Number" value="<%= admin.mobile || '' %>">
                                        </div>
                                        <div class="mb-3">
                                            <label class="col-form-label pt-0">Gender</label>
                                            <div class="col">
                                                <div class="m-t-15 m-checkbox-inline custom-radio-ml">
                                                    <div class="form-check form-check-inline radio radio-primary">
                                                        <input class="form-check-input" id="radioinline1" type="radio"
                                                            name="gender" value="male" <%= admin.gender === 'male' ? 'checked' : '' %>>
                                                        <label class="form-check-label mb-0"
                                                            for="radioinline1">Male</label>
                                                    </div>
                                                    <div class="form-check form-check-inline radio radio-primary">
                                                        <input class="form-check-input" id="radioinline2" type="radio"
                                                            name="gender" value="female" <%= admin.gender === 'female' ? 'checked' : '' %>
                                                            >
                                                        <label class="form-check-label mb-0"
                                                            for="radioinline2">Female</label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="mb-3">
                                            <label class="col-form-label pt-0">Hobby</label>
                                            <div class="col-sm-9">
                                                <div class="mb-0">
                                                    <div class="form-check form-check-inline checkbox checkbox-primary">
                                                        <input class="form-check-input" id="inline-form-1"
                                                            type="checkbox" value="writing" name="hobby" <%= hobbies.includes('writing') ? 'checked' : '' %> >
                                                        <label class="form-check-label" for="inline-form-1">Writing
                                                        </label>
                                                    </div>
                                                    <div class="form-check form-check-inline checkbox checkbox-primary">
                                                        <input class="form-check-input" id="inline-form-2"
                                                            type="checkbox" value="reading" name="hobby" <%= hobbies.includes('reading') ? 'checked' : '' %> >
                                                        <label class="form-check-label" for="inline-form-2">Reading
                                                        </label>
                                                    </div>
                                                    <div class="form-check form-check-inline checkbox checkbox-primary">
                                                        <input class="form-check-input" id="inline-form-3"
                                                            type="checkbox" value="travelling" name="hobby" <%= hobbies.includes('travelling') ? 'checked' : '' %>  >
                                                        <label class="form-check-label" for="inline-form-3">Travelling
                                                        </label>
                                                    </div>
                                                    <div class="form-check form-check-inline checkbox checkbox-primary">
                                                        <input class="form-check-input" id="inline-form-4"
                                                            type="checkbox" value="gaming" name="hobby" <%= hobbies.includes('gaming') ? 'checked' : '' %>  >
                                                        <label class="form-check-label" for="inline-form-4">Gaming
                                                        </label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="mb-3">
                                            <label class="col-form-label pt-0">City</label>
                                            <select name="city" class="js-example-basic-single col-sm-12">
                                                <optgroup>
                                                    <option value="Surat" <%= admin.city === 'Surat' ? 'selected' : '' %>>Surat</option>
                                                    <option value="Vadodara" <%= admin.city === 'Vadodara' ? 'selected' : '' %>>Vadodara</option>
                                                    <option value="Ahmedabad" <%= admin.city === 'Ahmedabad' ? 'selected' : '' %>>Ahmedabad</option>
                                                    <option value="Pune" <%= admin.city === 'Pune' ? 'selected' : '' %>>Pune</option>
                                                    <option value="Mumbai" <%= admin.city === 'Mumbai' ? 'selected' : '' %>>Mumbai</option>
                                                    <option value="Bengluru" <%= admin.city === 'Bengluru' ? 'selected' : '' %>>Bengluru</option>
                                                    <option value="Delhi" <%= admin.city === 'Delhi' ? 'selected' : '' %>>Delhi</option>
                                                </optgroup>
                                            </select>
                                        </div>
                                        <div class="mb-3">
                                            <label class="col-form-label pt-0">Role</label>
                                            <select name="role" class="js-example-basic-single col-sm-12"  >
                                                <optgroup>
                                                    <option value="Super Admin" <%= admin.role === 'Super Admin' ? 'selected' : '' %>>Super Admin</option>
                                                    <option value="Admin" <%= admin.role === 'Admin' ? 'selected' : '' %>>Admin</option>
                                                    <option value="Manager" <%= admin.role === 'Manager' ? 'selected' : '' %>>Manager</option>
                                                    <option value="Editor" <%= admin.role === 'Editor' ? 'selected' : '' %>>Editor</option>
                                                    <option value="User" <%= admin.role === 'User' ? 'selected' : '' %>>User</option>
                                                </optgroup>
                                            </select>
                                        </div>
                                        <div class="mb-3">
                                            <label class="col-form-label pt-0">Address</label>
                                            <textarea name="address" id="" class="w-100 form-control"
                                                style="resize: none; height: 100px;"  ><%= admin.address || '' %></textarea>
                                        </div>
                                        <div class="mb-3">
                                            <label for="avatar">Avatar</label>
                                            <% if (admin.avatar) { %>
                                                <div class="mb-2">
                                                    <img src="<%= admin.avatar %>" alt="Avatar" width="80" height="80">
                                                </div>
                                            <% } %>
                                            <input type="file" name="avatar" id="" class="w-100 form-control">
                                        </div>
                                        <div class="mb-3 pt-3">
                                            <button class="btn btn-primary" type="submit">Update</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Container-fluid Ends-->
    </div>
    <%- include('footer') %>
